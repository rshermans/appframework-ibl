# OpenAI
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
# OPENAI_MODEL — optional override. If omitted, hybrid model selection kicks in:
#   heavy tasks (evidence, structure) → gpt-5-mini
#   medium tasks (search design, explanation) → gpt-4o
#   fast tasks (topic generation, selection) → gpt-5-nano
#   fallback → gpt-4o-mini
# Set this only if you want to force a single model for ALL steps:
# OPENAI_MODEL=gpt-5-mini

# Database (Supabase)
DATABASE_URL=postgresql://postgres.<project-ref>:<your-password>@<your-host>:5432/postgres?sslmode=require
DIRECT_URL=postgresql://postgres.<project-ref>:<your-password>@<your-host>:5432/postgres?sslmode=require

# Database (local Postgres alternative)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/research_wizard
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/research_wizard

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
S2_API_KEY=your_semantic_scholar_api_key
