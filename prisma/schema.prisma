// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Optional in local/dev environments. Re-enable if a direct migration connection is required.
  // directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id        String   @id @default(cuid())
  topic     String
  stage     Int      @default(0)
  step      String   @default("step0")
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  interactions ProjectInteraction[]
  
  @@index([stage])
  @@index([step])
  @@index([userId])
}

model ProjectInteraction {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  stage     Int
  stepId    String
  stepLabel String
  
  userInput   String
  aiOutput    String
  
  mode      String?  // "quick", "advanced", etc
  tokens    Int      @default(0)

  // -- Telemetry Layer (Interaction Layer) --
  sessionId   String?
  metadata    Json?    // { device, version, app_url, etc }
  
  // -- Analytical Layers (JSONB) --
  cognitiveFeatures Json? // { bloom_level, complexity, argumentation, autonomy }
  affectiveFeatures Json? // { sentiment, confidence, frustration, engagement }
  learningMetrics   Json? // { progression, skill_trend, etc }

  processedAt DateTime? // When enrichment was completed
  createdAt   DateTime @default(now())
  
  @@index([projectId])
  @@index([stage])
  @@index([stepId])
  @@index([sessionId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  projects      Project[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
